# Supabase — these are public values (RLS protects the data).
# Set the same vars in your Vercel project for production.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_xxx

# ---------------------------------------------------------------------------
# Edge Function secrets (server-side only — NEVER prefix with VITE_ or expose
# to the browser). Set these with the Supabase CLI / dashboard:
#   supabase secrets set CHAPA_SECRET_KEY=...  (etc.)
# SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY are injected
# automatically into deployed functions; you only need them in supabase/.env
# for local `supabase functions serve`.
# ---------------------------------------------------------------------------

# Chapa payment gateway
CHAPA_SECRET_KEY=CHASECK_TEST-xxxx            # test key for test mode, live key for live mode
CHAPA_WEBHOOK_SECRET=your-chapa-webhook-secret-hash  # "Secret hash" from Chapa dashboard → Webhooks

# Base URL used to build the Chapa return_url (e.g. https://edl44.com)
SITE_URL=https://raffle.example.com

# Resend (confirmation + draw-notification emails)
RESEND_API_KEY=re_xxxx
RESEND_FROM_EMAIL=noreply@your-domain.com
